---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import wagashiPersimmon from '../assets/content/wagashi-persimmon-inline.jpg';

const DOWNLOAD_URL = '/downloads/tea-etiquette-guide.pdf';
---

<BaseLayout
  title="Your guide is on its way — Tokyo in Season"
  description="Thank you for subscribing to Tokyo in Season. Download your free Tea Ceremony Etiquette Guide for First-Time Guests."
>
  <div class="text-center py-8">

    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-sakura-light mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-sakura-deep" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
      </svg>
    </div>

    <h1 class="font-serif font-semibold text-3xl text-sumi mb-3">You're subscribed.</h1>
    <p class="text-sumi/70 max-w-sm mx-auto mb-8">
      Check your inbox for a confirmation email from Buttondown — click the link inside, then your guide will be on its way.
    </p>

    <div class="inline-block bg-sakura-light border border-sakura rounded-xl p-6 mb-10 text-left max-w-sm w-full">
      <Image
        src={wagashiPersimmon}
        alt="A persimmon-shaped wagashi sweet on seasonal washi paper"
        widths={[300, 600]}
        sizes="384px"
        class="w-full h-40 object-cover rounded-lg mb-4"
      />
      <p class="font-sans text-xs font-semibold text-sakura-deep uppercase tracking-wide mb-2">Free download</p>
      <p class="font-serif text-lg text-sumi leading-snug mb-1">Tea Ceremony Etiquette for First-Time Guests</p>
      <p class="text-sm text-warm-gray-mid mb-4">A practitioner's guide, from inside the tea room — by Suzu</p>
      <a
        href={DOWNLOAD_URL}
        download
        class="inline-flex items-center gap-2 bg-sakura-deep hover:bg-matcha text-white font-sans font-medium text-sm px-5 py-2.5 rounded transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        Download PDF
      </a>
    </div>

    <p class="text-sm text-sumi/70 mb-8">
      You'll also receive seasonal updates — new openings, price changes, and what's actually worth booking right now.
      Unsubscribe any time.
    </p>

    <div class="flex flex-wrap justify-center gap-4 text-sm">
      <a href="/tokyo-tea-ceremony-compared" class="text-matcha underline">Compare all Tokyo experiences →</a>
      <a href="/" class="text-sumi/70 underline hover:text-matcha">Back to home</a>
    </div>

  </div>
</BaseLayout>
