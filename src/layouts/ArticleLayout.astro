---
import BaseLayout from './BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
import AuthorBio from '../components/AuthorBio.astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  category?: string;
  tags?: string[];
  hasAffiliateLinks?: boolean;
}

const { title, description, publishDate, updatedDate, tags = [], hasAffiliateLinks = false } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description} ogType="article" hasAffiliateLinks={hasAffiliateLinks}>
  <article>
    <header class="mb-10">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map(tag => (
            <span class="text-xs font-medium text-sakura-deep bg-sakura-light border border-sakura rounded-full px-3 py-0.5">
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="font-serif font-semibold text-4xl text-sumi leading-tight mb-4 text-wrap-balance">
        {title}
      </h1>
      <p class="text-sm text-warm-gray-mid">
        <time datetime={publishDate.toISOString()}>
          {dateFormatter.format(publishDate)}
        </time>
        {updatedDate && (
          <span> · Updated <time datetime={updatedDate.toISOString()}>{dateFormatter.format(updatedDate)}</time></span>
        )}
      </p>
    </header>

    <div class="prose prose-lg max-w-none text-sumi">
      <slot />
    </div>

    <div class="mt-12 pt-8 border-t border-warm-gray">
      <AuthorBio />
      <EmailCapture />
    </div>
  </article>
</BaseLayout>
