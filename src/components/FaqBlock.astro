---
interface FaqItem {
  question: string;
  answer: string;
}
interface Props {
  items: FaqItem[];
}
const { items } = Astro.props;
---

<section class="faq-block my-10">
  <h2 class="font-serif font-semibold text-2xl text-sumi mb-6">Frequently Asked Questions</h2>
  <dl class="space-y-4">
    {items.map((item) => (
      <div class="border border-warm-gray-mid rounded-lg overflow-hidden">
        <dt class="font-sans font-semibold text-sumi p-4 bg-warm-gray">{item.question}</dt>
        <dd class="p-4 text-sumi leading-relaxed text-sm">{item.answer}</dd>
      </div>
    ))}
  </dl>
</section>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
})} />
