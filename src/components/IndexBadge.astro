}
const { quarter } = Astro.props;
---

<div class="inline-flex items-center gap-2 bg-sakura-light border border-sakura text-sakura-deep rounded-full px-3 py-1.5 text-xs font-sans font-semibold tracking-wide">
  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
    <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm2 10a1 1 0 10-2 0v3a1 1 0 102 0v-3zm2-3a1 1 0 011 1v5a1 1 0 11-2 0v-5a1 1 0 011-1zm4-1a1 1 0 10-2 0v7a1 1 0 102 0V8z" clip-rule="evenodd"/>
  </svg>
  Data: Tokyo Tea Ceremony Price Index · Updated {quarter}
</div>
