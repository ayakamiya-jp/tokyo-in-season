---
import AffiliateButton from './AffiliateButton.astro';

interface Experience {
  name: string;
  provider: string;
  affiliate_url: string;
  affiliate_network: 'getyourguide' | 'klook' | 'direct';
  price_jpy: number;
  duration_min: number;
  area: string;
  english_support: boolean;
  seiza_optional: boolean;
  kimono_addon: boolean;
  private_available: boolean;
  group_size_max: number;
  rating?: number;
  review_count?: number;
  school: string;
  editor_note: string;
}

interface Props {
  experiences: Experience[];
  quarter: string;
}

const { experiences, quarter } = Astro.props;

const sorted = [...experiences].sort((a, b) => a.price_jpy - b.price_jpy);
const icon = (v: boolean) => v ? '✓' : '—';
---

<div class="overflow-x-auto my-8">
  <p class="text-xs text-warm-gray-mid mb-2">
    Sorted by price · Data: Tokyo Tea Ceremony Price Index {quarter}
  </p>
  <table class="w-full text-sm border-collapse">
    <thead>
      <tr class="bg-warm-gray text-left">
        <th class="p-3 font-sans font-semibold text-sumi border-b border-warm-gray-mid">Experience</th>
        <th class="p-3 font-sans font-semibold text-sumi border-b border-warm-gray-mid">Price</th>
        <th class="p-3 font-sans font-semibold text-sumi border-b border-warm-gray-mid">Area</th>
        <th class="p-3 font-sans font-semibold text-sumi border-b border-warm-gray-mid">Duration</th>
        <th class="p-3 font-sans font-semibold text-sumi border-b border-warm-gray-mid">Chairs</th>
        <th class="p-3 font-sans font-semibold text-sumi border-b border-warm-gray-mid">Kimono</th>
        <th class="p-3 font-sans font-semibold text-sumi border-b border-warm-gray-mid">Private</th>
        <th class="p-3 font-sans font-semibold text-sumi border-b border-warm-gray-mid">Book</th>
      </tr>
    </thead>
    <tbody>
      {sorted.map((exp, i) => (
        <tr class:list={["border-b border-warm-gray-mid", i % 2 === 0 ? "bg-white" : "bg-warm-gray/40"]}>
          <td class="p-3">
            <p class="font-semibold text-sumi">{exp.name}</p>
            <p class="text-xs text-warm-gray-mid">{exp.provider} · {exp.school}</p>
            {exp.rating && (
              <p class="text-xs text-matcha mt-0.5">★ {exp.rating} ({exp.review_count?.toLocaleString()} reviews)</p>
            )}
            <p class="text-xs italic text-sumi/70 mt-1">"{exp.editor_note}"</p>
          </td>
          <td class="p-3 font-semibold text-sumi whitespace-nowrap">¥{exp.price_jpy.toLocaleString()}</td>
          <td class="p-3 text-sumi">{exp.area}</td>
          <td class="p-3 text-sumi whitespace-nowrap">{exp.duration_min} min</td>
          <td class:list={["p-3 text-center", exp.seiza_optional ? "text-matcha font-bold" : "text-warm-gray-mid"]}>{icon(exp.seiza_optional)}</td>
          <td class:list={["p-3 text-center", exp.kimono_addon ? "text-matcha font-bold" : "text-warm-gray-mid"]}>{icon(exp.kimono_addon)}</td>
          <td class:list={["p-3 text-center", exp.private_available ? "text-matcha font-bold" : "text-warm-gray-mid"]}>{icon(exp.private_available)}</td>
          <td class="p-3">
            <AffiliateButton url={exp.affiliate_url} network={exp.affiliate_network} price_jpy={exp.price_jpy} />
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Tokyo Tea Ceremony Experiences — ${quarter}`,
  "description": "Curated list of bookable tea ceremony experiences in Tokyo, ranked by price.",
  "itemListElement": sorted.map((exp, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": exp.name,
    "url": exp.affiliate_url,
  })),
})} />
