---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<aside class:list={["author-bio border-l-4 border-sakura bg-sakura-light rounded-r-lg", compact ? "p-4" : "p-6 my-8"]}>
  <div class="flex items-start gap-4">
    <img
      src="/favicon.svg"
      alt="Suzu, Urasenke tea ceremony practitioner"
      class="w-16 h-16 rounded-full flex-shrink-0"
      width="64"
      height="64"
    />
    <div>
      <p class="font-semibold text-sumi text-sm uppercase tracking-wide mb-1">Written by</p>
      <p class="font-serif font-semibold text-lg text-sumi leading-tight">Suzu</p>
      <p class="text-sm text-warm-gray-mid mt-1">
        Urasenke-trained tea ceremony practitioner based in Tokyo. I write about authentic
        Japanese cultural experiences to help travellers find the real thing.
      </p>
      {!compact && (
        <p class="text-xs text-warm-gray-mid mt-2">
          <a href="/about" class="underline hover:text-matcha">Learn more about my practice →</a>
        </p>
      )}
    </div>
  </div>
</aside>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Suzu",
  "description": "Urasenke tea ceremony practitioner and Japanese culture guide author based in Tokyo",
  "url": "https://tokyoinseason.com/about",
  "knowsAbout": ["Tea Ceremony", "Japanese Culture", "Urasenke", "Wabi-sabi", "Wagashi"]
}
</script>
