---
interface Props {
  url: string;
  network: 'getyourguide' | 'klook' | 'direct';
  label?: string;
  price_jpy?: number;
}

const { url, network, label, price_jpy } = Astro.props;

const networkLabel = {
  getyourguide: 'Book on GetYourGuide',
  klook: 'Book on Klook',
  direct: 'Book Direct',
}[network];

const displayLabel = label ?? networkLabel;
const priceText = price_jpy ? ` · from ¥${price_jpy.toLocaleString()}` : '';
---

<a
  href={url}
  target="_blank"
  rel="noopener sponsored"
  class="inline-flex items-center gap-2 bg-matcha hover:bg-matcha-light text-white font-sans font-medium px-6 py-3 rounded-md transition-colors duration-200 text-sm"
>
  {displayLabel}{priceText}
  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
    <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
    <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
  </svg>
</a>
<p class="text-xs text-warm-gray-mid mt-1">
  This is an affiliate link. I earn a small commission at no extra cost to you.
</p>
